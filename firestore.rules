rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // Profile Validation
    function isValidProfile(p) {
      return p.display_name is string && p.display_name.size() > 0 && p.display_name.size() <= 100 &&
             (p.avatar_url == null || (p.avatar_url is string && p.avatar_url.size() <= 500)) &&
             p.city is string && p.city.size() <= 200 &&
             p.latitude is number && p.latitude >= -90 && p.latitude <= 90 &&
             p.longitude is number && p.longitude >= -180 && p.longitude <= 180 &&
             p.user_type in ['business', 'fun'] &&
             (p.bio == null || (p.bio is string && p.bio.size() <= 500)) &&
             p.is_visible is bool &&
             p.tier in ['member', 'paid'];
    }

    match /profiles/{userId} {
      allow get: if (existing().is_visible == true || isSignedIn());
      allow list: if (existing().is_visible == true || isSignedIn());
      
      allow create: if isOwner(userId) &&
                       isValidProfile(incoming()) &&
                       incoming().created_at == request.time &&
                       incoming().updated_at == request.time;
      
      allow update: if isOwner(userId) &&
                       isValidProfile(incoming()) &&
                       incoming().created_at == existing().created_at &&
                       incoming().updated_at == request.time &&
                       // Action: Profile Update
                       (incoming().diff(existing()).affectedKeys().hasOnly([
                         'display_name', 'avatar_url', 'city', 'latitude', 'longitude', 
                         'user_type', 'bio', 'instagram_handle', 'twitter_handle', 
                         'is_visible', 'updated_at'
                       ]));

      match /notifications/{notificationId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && incoming().created_at == request.time;
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['is_read']);
      }

      match /preferences/notifications {
        allow read, write: if isOwner(userId);
      }
    }

    match /invite_codes/{codeId} {
      allow read, write: if false; // System only
    }

    match /blocks/{blockId} {
      // blocker_id, blocked_id, created_at
      allow read: if isSignedIn() && (resource.data.blocker_id == request.auth.uid || resource.data.blocked_id == request.auth.uid);
      allow create: if isSignedIn() && 
                       incoming().blocker_id == request.auth.uid &&
                       incoming().created_at == request.time;
      allow delete: if isSignedIn() && resource.data.blocker_id == request.auth.uid;
    }

    match /messages/{messageId} {
      // user_id, content, created_at
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                       incoming().user_id == request.auth.uid &&
                       incoming().content is string && 
                       incoming().content.size() > 0 && 
                       incoming().content.size() <= 1000 &&
                       incoming().created_at == request.time;
    }

    match /reports/{reportId} {
      // reporter_id, reported_id, content_type, reason, status, created_at
      allow read: if isAdmin();
      allow create: if isSignedIn() && 
                       incoming().reporter_id == request.auth.uid &&
                       incoming().reported_id is string &&
                       incoming().reason is string &&
                       incoming().reason.size() > 0 &&
                       incoming().reason.size() <= 500 &&
                       incoming().status == 'pending' &&
                       incoming().created_at == request.time;
      allow update: if isAdmin() && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    // Waitlist Validation
    function isValidWaitlist(w) {
      return w.email is string && w.email.size() <= 200 &&
             w.latitude is number && w.longitude is number &&
             (w.user_type == 'business' || w.user_type == 'fun') &&
             w.status == 'pending' &&
             w.created_at == request.time;
    }

    match /waitlist/{id} {
      allow create: if isValidWaitlist(incoming());
      allow read, update, delete: if isAdmin();
    }

    // Lead Validation
    function isValidLead(l) {
      return l.email is string && l.email.size() > 0 && l.email.size() <= 200 &&
             l.pins is list && l.pins.size() <= 10 &&
             l.created_at == request.time;
    }

    match /leads/{leadId} {
      allow create: if isValidLead(incoming());
      allow read, update, delete: if isAdmin();
    }

    // Anonymous Chat Validation
    function isValidAnonymousMessage(m) {
      return m.text is string && m.text.size() > 0 && m.text.size() <= 500 &&
             m.senderName is string && m.senderName.size() <= 100 &&
             m.senderColor is string && m.senderColor.size() <= 32 &&
             m.timestamp == request.time;
    }

    match /anonymous_chat/{messageId} {
      allow list: if true;
      allow get: if true;
      allow create: if isValidAnonymousMessage(incoming());
    }

    match /daily_horoscopes/{dateId} {
      allow read, write: if true; 
    }

    // Posts Validation
    function isValidPost(p) {
      return p.title is string && p.title.size() > 0 && p.title.size() <= 200 &&
             p.email is string && p.email.size() > 0 && p.email.size() <= 200 &&
             p.city is string && p.city.size() <= 200 &&
             p.latitude is number && p.latitude >= -90 && p.latitude <= 90 &&
             p.longitude is number && p.longitude >= -180 && p.longitude <= 180 &&
             p.type in ['job', 'event'] &&
             (p.description == null || (p.description is string && p.description.size() <= 1000)) &&
             (p.flyer_url == null || (p.flyer_url is string && p.flyer_url.size() <= 1000));
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isValidPost(incoming()) && 
                       incoming().created_at == request.time;
      allow update, delete: if isAdmin();
    }
  }
}
