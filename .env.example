# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE: Required for database and auth
# Prefix with VITE_ to expose to the React frontend
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# GEOCODING: Required to convert cities to lat/lng (OpenCage)
OPENCAGE_API_KEY="your-opencage-key"

# STRIPE: Required for paid memberships
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# EMAIL: Required for sending welcome emails (Resend)
RESEND_API_KEY=

# POSTHOG: Required for analytics
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
