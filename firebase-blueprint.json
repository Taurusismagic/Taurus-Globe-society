{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Public and private user data stored on the maps node.",
      "type": "object",
      "properties": {
        "display_name": { "type": "string" },
        "avatar_url": { "type": "string" },
        "city": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "user_type": { "type": "string", "enum": ["business", "fun"] },
        "bio": { "type": "string" },
        "instagram_handle": { "type": "string" },
        "twitter_handle": { "type": "string" },
        "is_visible": { "type": "boolean" },
        "tier": { "type": "string", "enum": ["member", "paid"] },
        "stripe_customer_id": { "type": "string" },
        "stripe_subscription_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["display_name", "city", "latitude", "longitude", "user_type", "tier", "is_visible"]
    },
    "InviteCode": {
      "title": "Invite Code",
      "description": "Controls access to joining the tribe.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "uses_so_far": { "type": "number" },
        "max_uses": { "type": "number" },
        "is_active": { "type": "boolean" }
      },
      "required": ["code", "uses_so_far", "max_uses", "is_active"]
    },
    "Block": {
      "title": "User Block",
      "description": "Blocking relationship between users.",
      "type": "object",
      "properties": {
        "blocker_id": { "type": "string" },
        "blocked_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["blocker_id", "blocked_id", "created_at"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "Global chat messages.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "author_name": { "type": "string" },
        "author_avatar": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "content", "created_at", "author_name"]
    },
    "Report": {
      "title": "User Report",
      "description": "Reports of misconduct.",
      "type": "object",
      "properties": {
        "reporter_id": { "type": "string" },
        "reported_id": { "type": "string" },
        "content_type": { "type": "string", "enum": ["message", "profile"] },
        "content_id": { "type": "string" },
        "reason": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["reporter_id", "reported_id", "content_type", "reason", "status", "created_at"]
    },
    "Waitlist": {
      "title": "Waitlist Entry",
      "description": "Access request for the platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "chat1_lat": { "type": ["number", "null"] },
        "chat1_lng": { "type": ["number", "null"] },
        "chat2_lat": { "type": ["number", "null"] },
        "chat2_lng": { "type": ["number", "null"] },
        "user_type": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "latitude", "longitude", "status", "created_at"]
    },
    "leads": {
      "title": "Lead",
      "description": "Captured emails from the onboarding funnel",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "pins": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "created_at"]
    },
    "AnonymousMessage": {
      "title": "Anonymous Message",
      "description": "Messages sent through the cinematic chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderName", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app alerts for users.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["system", "message", "task", "update"] },
        "is_read": { "type": "boolean" },
        "link": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "is_read", "created_at"]
    },
    "NotificationPreferences": {
      "title": "Notification Preferences",
      "description": "User settings for notifications.",
      "type": "object",
      "properties": {
        "system_enabled": { "type": "boolean" },
        "message_enabled": { "type": "boolean" },
        "task_enabled": { "type": "boolean" },
        "update_enabled": { "type": "boolean" },
        "email_digest": { "type": "boolean" }
      },
      "required": ["system_enabled", "message_enabled", "task_enabled", "update_enabled"]
    },
    "Post": {
      "title": "Job/Event Post",
      "description": "Community posts for jobs or events.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "email": { "type": "string" },
        "city": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "flyer_url": { "type": "string" },
        "type": { "type": "string", "enum": ["job", "event"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "email", "city", "latitude", "longitude", "type", "created_at"]
    },
    "DirectMessage": {
      "title": "Direct Message",
      "description": "Private messages between users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "user_id": { "type": "string" },
        "recipient_id": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "user_id", "content", "created_at"]
    },
    "PromotionRequest": {
      "title": "Promotion Request",
      "description": "Requests for account promotion (e.g., via Stripe).",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "tier": { "type": "string", "enum": ["paid"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "status", "tier", "created_at"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of community job/event posts"
    },
    "/leads/{leadId}": {
      "schema": "leads",
      "description": "Collection of emails from the nexus funnel"
    },
    "profiles/{userId}": {
      "schema": "Profile",
      "description": "User profiles."
    },
    "profiles/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Per-user notifications."
    },
    "profiles/{userId}/preferences/notifications": {
      "schema": "NotificationPreferences",
      "description": "User notification settings."
    },
    "invite_codes/{codeId}": {
      "schema": "InviteCode",
      "description": "Invite codes."
    },
    "blocks/{blockId}": {
      "schema": "Block",
      "description": "User block records."
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Global chat messages."
    },
    "reports": {
      "schema": "Report",
      "description": "Moderation reports."
    },
    "waitlist/{id}": {
      "schema": "Waitlist",
      "description": "Access requests for the nexus."
    },
    "anonymous_chat/{messageId}": {
      "schema": "AnonymousMessage",
      "description": "Anonymous messages for the cinematic chat."
    },
    "direct_messages/{messageId}": {
      "schema": "DirectMessage",
      "description": "User direct messages."
    },
    "promotion_requests/{requestId}": {
      "schema": "PromotionRequest",
      "description": "Account promotion requests."
    }
  }
}
